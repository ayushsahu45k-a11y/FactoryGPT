# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# -------------------------------------------------------------
# PRODUCTION DEPLOYMENT SETTINGS (FactoryGPT Orchestrated Stack)
# -------------------------------------------------------------

# Secret key used to sign and verify JWT authorization tokens
JWT_SECRET_KEY="f797df77e23a3cb85eb9372d61fe219cfac6ea058e8a8b139db080e7747ebd4b"

# Async Connection URLs for internal microservice communication 
DATABASE_URL="postgresql+asyncpg://postgres:industrial_pass@postgres:5432/factorygpt"
REDIS_URL="redis://redis:6379/0"

# SQL Engine parameters
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="industrial_pass"
POSTGRES_DB="factorygpt"

# Performance Dashboard metrics panel credentials
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="factory_admin_pass"

